{
  "name": "roxy",
  "version": "0.0.43",
  "description": "Roxy — an open-source AI coding agent for engineers.",
  "main": "./out/main/index.js",
  "author": "Roxy (https://github.com/FreddyJD/roxy)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FreddyJD/roxy.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node script/predev.mjs",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "dist:mac": "bash script/build-mac.sh",
    "dist:mac:publish": "bash script/build-mac.sh --publish always",
    "release": "npm run build && electron-builder --publish always",
    "release:win": "npm run build && electron-builder --win --publish always",
    "release:mac": "npm run build && electron-builder --mac --publish always",
    "release:linux": "npm run build && electron-builder --linux --publish always",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "icons": "node script/generate-icons.mjs",
    "icons:providers": "node script/copy-provider-icons.mjs",
    "smoke:shared": "esbuild test/shared.ts --bundle --platform=node --format=cjs --packages=external --outfile=test/.out/shared.cjs && node test/.out/shared.cjs",
    "smoke:app": "esbuild test/smoke.ts --bundle --platform=node --format=cjs --packages=external --outfile=test/.out/smoke.cjs && electron test/.out/smoke.cjs",
    "smoke": "npm run smoke:shared && npm run smoke:app"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.85",
    "@ai-sdk/google": "^2.0.78",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pierre/diffs": "^1.2.11",
    "ai": "^5.0.210",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^1.21.0",
    "qrcode.react": "^4.2.0",
    "react-router-dom": "^7.18.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tinyglobby": "^0.2.17",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png2icons": "^2.0.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
